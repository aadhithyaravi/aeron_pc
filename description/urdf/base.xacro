<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= PROPERTIES ================= -->

  <!--
    24 inch = 0.6096m → X axis (WIDE,  left to right)
    16 inch = 0.4064m → Y axis (SHORT, front to back)
  -->
  <xacro:property name="base_length" value="0.6096"/>  <!-- X = 24inch -->
  <xacro:property name="base_width"  value="0.4064"/>  <!-- Y = 16inch -->
  <xacro:property name="base_height" value="0.10"/>
  <xacro:property name="base_mass"   value="18.5"/>  <!-- 15.0 + ~3.5kg wood -->

  <xacro:property name="wheel_radius" value="0.03175"/>
  <xacro:property name="wheel_width"  value="0.0203"/>
  <xacro:property name="wheel_mass"   value="0.5"/>

  <xacro:property name="caster_radius" value="0.025"/>
  <xacro:property name="caster_width"  value="0.02"/>
  <xacro:property name="caster_mass"   value="0.2"/>

  <!--
    Drive wheels: x = 0.0     (centered on 24inch X axis)
                  y = ±0.17   (along 16inch Y axis)
    Casters:      x = ±0.27   (along 24inch X axis)
                  y = ±0.17   (along 16inch Y axis)
  -->
  <xacro:property name="wheel_x_offset" value="0.27"/>
  <xacro:property name="wheel_y_offset" value="0.17"/>
  <xacro:property name="front_y"        value=" 0.17"/>
  <xacro:property name="rear_y"         value="-0.17"/>

  <!-- ================= MATERIALS ================= -->

  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  <material name="wood">
    <color rgba="0.6 0.4 0.2 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.1 0.1 0.8 1.0"/>
  </material>

  <!-- ================= BASE FOOTPRINT ================= -->

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${base_height/2.0 + wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ================= BASE LINK ================= -->

  <link name="base_link">

    <!-- Chassis box: x=24inch, y=16inch, z=height -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="grey"/>
    </visual>

    <!-- Wooden top layer (1 inch thick) -->
    <visual>
      <origin xyz="0 0 ${base_height/2.0 + 0.0254/2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length - 0.02} ${base_width - 0.02} 0.0254"/>
      </geometry>
      <material name="wood"/>
    </visual>

    <collision>
      <origin xyz="0 0 ${base_height/2.0 + 0.0254/2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length - 0.02} ${base_width - 0.02} 0.0254"/>
      </geometry>
    </collision>

    <!-- Front marker (blue strip at +Y face) -->
    <visual>
      <origin xyz="0 ${base_width/2.0 - 0.01} ${base_height/2.0 + 0.006}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length - 0.04} 0.02 0.004"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="${base_mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!--
        x=0.6096, y=0.4064, z=0.10 + 0.0254 = 0.1254 (with wood)
        Total mass = 18.5kg
        ixx = m/12*(y^2+z^2) = 18.5/12*(0.1652+0.0157)  = 0.318
        iyy = m/12*(x^2+z^2) = 18.5/12*(0.3716+0.0157)  = 0.679
        izz = m/12*(x^2+y^2) = 18.5/12*(0.3716+0.1652) = 0.944
      -->
      <inertia ixx="0.318" ixy="0.0" ixz="0.0"
               iyy="0.679" iyz="0.0"
               izz="0.944"/>
    </inertial>

  </link>

</robot>
