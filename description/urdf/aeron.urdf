      <geometry>
        <box size="0.5696 0.02 0.004"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.6096 0.4064 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="18.5"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <!--
        x=0.6096, y=0.4064, z=0.10 + 0.0254 = 0.1254 (with wood)
        Total mass = 18.5kg
        ixx = m/12*(y^2+z^2) = 18.5/12*(0.1652+0.0157)  = 0.318
        iyy = m/12*(x^2+z^2) = 18.5/12*(0.3716+0.0157)  = 0.679
        izz = m/12*(x^2+y^2) = 18.5/12*(0.3716+0.1652) = 0.944
      -->
      <inertia ixx="0.318" ixy="0.0" ixz="0.0" iyy="0.679" iyz="0.0" izz="0.944"/>
    </inertial>
  </link>
  <!--
    DRIVE WHEEL MACRO
    ─────────────────
    LW and RW sit at x=0, y=±0.17 (on Y axis for differential drive).
    Robot moves forward/backward along Y (16inch short axis).
    
    Wheel joint configuration for differential drive:
    - Cylinder default orientation = Z (vertical).
    - rpy="1.5708 0 0" → rotate 90° around X
      → cylinder axis becomes Y
      → flat faces point along X (left/right) ✓
    - For differential drive with wheels separated along Y:
      wheels must rotate around vertical axis (Z) to produce forward motion
    - axis="0 1 0" in joint frame (local Y) → after rotation, local Y = world Z (vertical)
      so rotating around local Y = rotating around world Z ✓
      this enables differential drive kinematics ✓
  -->
  <!--
    CASTER WHEEL MACRO
    ──────────────────
    Passive corners. Same X offset as drive wheels.
    Front at +Y, rear at -Y.

    swivel → free Z yaw (any direction)
    wheel  → rolls along Y same as drive wheels
             rpy="1.5708 0 0" ✓
  -->
